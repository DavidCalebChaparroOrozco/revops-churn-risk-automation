# --- LLM providers ---
# At least ONE of OPENAI_API_KEY / GEMINI_API_KEY must be set.
# If both are set, OpenAI is tried first and Gemini is used as an
# automatic failover if OpenAI fails (quota, outage, timeout, etc.).
# See llm_providers.py and app.py::_build_providers().

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Gemini (get a key at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXXXXXX

# --- App config ---
# Minimum score threshold to consider an account "at risk" (see risk.py)
RISK_SCORE_THRESHOLD=3
